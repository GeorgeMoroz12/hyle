---
// src/layouts/Layout.astro
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
    title?: string; // Fallback заголовок
    description?: string; // Fallback описание
    image?: string; // Fallback картинка
    seo?: {
        // Объект из CMS
        title?: string;
        description?: string;
        ogImage?: string;
    };
    hideHeader?: boolean;
}

const {
    title = "Керамика ручной работы",
    description = "Авторская керамика ручной работы Хилẽ. Посуда с характером, созданная в тишине.",
    image = "/images/hero-minimal.jpg",
    seo = {},
    hideHeader = false,
} = Astro.props;

// --- CASCADE LOGIC ---
// 1. Берем из SEO-блока CMS
// 2. Если нет — берем проп title/description (переданный со страницы)
// 3. Если нет — дефолтные значения (выше)
const finalTitle = seo.title || title;
const finalDescription = seo.description || description;
const finalImage = seo.ogImage || image;

// Формируем полный URL для OG картинки
const siteUrl = Astro.site ? Astro.site.href : "https://hyle-ceramics.com"; // Замените на реальный домен
const ogImageUrl = finalImage.startsWith("http")
    ? finalImage
    : new URL(finalImage, siteUrl).href;
---

<!doctype html>
<html lang="ru">
    <head>
        <meta charset="UTF-8" />
        <meta
            name="viewport"
            content="width=device-width, initial-scale=1, viewport-fit=cover"
        />
        <meta name="format-detection" content="telephone=no" />

        <!-- Yandex.Metrika counter -->
        <script type="text/javascript">
            (function(m,e,t,r,i,k,a){
                m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
                m[i].l=1*new Date();
                for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
                k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)
            })(window, document,'script','https://mc.yandex.ru/metrika/tag.js?id=107221259', 'ym');

            ym(107221259, 'init', {ssr:true, webvisor:true, clickmap:true, ecommerce:"dataLayer", referrer: document.referrer, url: location.href, accurateTrackBounce:true, trackLinks:true});
        </script>
        <noscript><div><img src="https://mc.yandex.ru/watch/107221259" style="position:absolute; left:-9999px;" alt="" /></div></noscript>
        <!-- /Yandex.Metrika counter -->

        <link rel="icon" type="image/png" href="/favicon.png" />

        <!-- PRIMARY META -->
        <title>{finalTitle} | Хилẽ</title>
        <meta name="title" content={finalTitle} />
        <meta name="description" content={finalDescription} />

        <!-- OPEN GRAPH / FACEBOOK -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content={Astro.url.href} />
        <meta property="og:title" content={finalTitle} />
        <meta property="og:description" content={finalDescription} />
        <meta property="og:image" content={ogImageUrl} />

        <!-- TWITTER -->
        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={Astro.url.href} />
        <meta property="twitter:title" content={finalTitle} />
        <meta property="twitter:description" content={finalDescription} />
        <meta property="twitter:image" content={ogImageUrl} />

        <!-- FONTS -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Caveat:wght@400..700&family=Inter:wght@300;400;500;800&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap"
            rel="stylesheet"
        />
    </head>
    <body
        class="flex flex-col min-h-screen min-h-[100dvh] w-full antialiased selection:bg-hyle-clay/20 selection:text-hyle-text"
    >
        {!hideHeader && <Header />}

        <main class="flex-grow w-full min-w-0 overflow-x-hidden">
            <slot />
        </main>

        {!hideHeader && <Footer />}
    </body>
</html>
